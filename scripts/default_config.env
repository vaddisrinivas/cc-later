# cc-later configuration
# Empty PATHS_WATCH means: auto-watch the current repo where the hook runs.
PATHS_WATCH=

LATER_PATH=.claude/LATER.md
LATER_MAX_ENTRIES_PER_DISPATCH=3
LATER_AUTO_GITIGNORE=true

# Dispatch settings
DISPATCH_ENABLED=true
DISPATCH_MODEL=sonnet
DISPATCH_ALLOW_FILE_WRITES=false
DISPATCH_OUTPUT_PATH=~/.cc-later/results/{repo}-{date}.json

# window_aware: use Claude JSONL usage window
# time_based: only dispatch inside WINDOW_FALLBACK_DISPATCH_HOURS
# always: dispatch whenever idle
WINDOW_DISPATCH_MODE=window_aware
WINDOW_TRIGGER_AT_MINUTES_REMAINING=30
WINDOW_IDLE_GRACE_PERIOD_MINUTES=10
# Comma-separated HH:MM-HH:MM ranges, e.g. 09:00-17:00,22:00-24:00
WINDOW_FALLBACK_DISPATCH_HOURS=
# Comma-separated paths to JSONL files (leave empty to auto-detect)
WINDOW_JSONL_PATHS=

LIMITS_WEEKLY_BUDGET_TOKENS=10000000
LIMITS_BACKOFF_AT_PCT=80

# Resume tasks that failed due to rate/usage limits in the next fresh window.
AUTO_RESUME_ENABLED=true
AUTO_RESUME_MIN_REMAINING_MINUTES=240
