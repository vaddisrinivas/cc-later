{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/handler.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "(?i)(later\\s*(\\[!\\])?\\s*:|add\\s+(?:this\\s+)?to\\s+later\\s*:|note\\s+(?:this\\s+)?for\\s+later\\s*:|queue\\s+(?:this\\s+)?for\\s+later\\s*:|for\\s+later\\s*:)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/capture.py",
            "timeout": 4000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/compact.py",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
